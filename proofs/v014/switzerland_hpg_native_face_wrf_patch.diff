+!WRFGPU2_HPG_DECL_BEGIN  v0.14 fable native-face savepoint (env-gated, additive-only)
+   LOGICAL, SAVE :: hpg_inited  = .FALSE.
+   LOGICAL, SAVE :: hpg_enabled = .FALSE.
+   INTEGER, SAVE :: hpg_ncall   = 0
+   INTEGER, SAVE :: hpg_lo      = -1
+   INTEGER, SAVE :: hpg_hi      = -2
+   INTEGER, SAVE :: hpg_first   = 0
