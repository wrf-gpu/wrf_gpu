+     WRITE(hpg_bin) (((php(i,k,j), i=hpg_i0,hpg_i1), k=kds,kde-1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) (((alt(i,k,j), i=hpg_i0,hpg_i1), k=kds,kde-1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) (((al (i,k,j), i=hpg_i0,hpg_i1), k=kds,kde-1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) (((p  (i,k,j), i=hpg_i0,hpg_i1), k=kds,kde-1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) (((pb (i,k,j), i=hpg_i0,hpg_i1), k=kds,kde-1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) (((cqu(i,k,j), i=hpg_i0,hpg_i1), k=kds,kde-1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) (((cqv(i,k,j), i=hpg_i0,hpg_i1), k=kds,kde-1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) ((muu(i,j),   i=hpg_i0,hpg_i1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) ((muv(i,j),   i=hpg_i0,hpg_i1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) ((mu(i,j),    i=hpg_i0,hpg_i1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) ((msfux(i,j), i=hpg_i0,hpg_i1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) ((msfuy(i,j), i=hpg_i0,hpg_i1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) ((msfvx(i,j), i=hpg_i0,hpg_i1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) ((msfvy(i,j), i=hpg_i0,hpg_i1), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) (((hpg_t1y(i,k,j), i=hpg_i0,hpg_i1), k=kds,kde), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) (((hpg_t2y(i,k,j), i=hpg_i0,hpg_i1), k=kds,kde), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) (((hpg_t3y(i,k,j), i=hpg_i0,hpg_i1), k=kds,kde), j=hpg_j0,hpg_j1)
+     WRITE(hpg_bin) (((hpg_t4y(i,k,j), i=hpg_i0,hpg_i1), k=kds,kde), j=hpg_j0,hpg_j1)
