+      INTEGER :: wrfgpu2_ios, wrfgpu2_unit
+      INTEGER :: wrfgpu2_ij, wrfgpu2_i, wrfgpu2_j, wrfgpu2_k, wrfgpu2_mass_k_end
+
+      wrfgpu2_env = ''
+      CALL GET_ENVIRONMENT_VARIABLE('WRFGPU2_STEP1_PART1_PHYSICS_STATE_MUTATION', wrfgpu2_env)
