 CONTAINS
 
+!WRFGPU2_AWD_CTX_BEGIN  called once per acoustic iteration from solve_em
+SUBROUTINE wrfgpu2_awd_set_context( itimestep, rk_step, iteration )
+   IMPLICIT NONE
+   INTEGER, INTENT(IN) :: itimestep, rk_step, iteration
+   CHARACTER(LEN=512) :: ev
+   INTEGER :: ios
+   IF (.NOT. awd_inited) THEN
+     awd_inited = .TRUE.
+     CALL GET_ENVIRONMENT_VARIABLE('WRFGPU2_AWD', ev)
+     IF (TRIM(ev) == '1') awd_enabled = .TRUE.
+     IF (awd_enabled) THEN
+       CALL GET_ENVIRONMENT_VARIABLE('WRFGPU2_AWD_STEP', ev)
+       IF (LEN_TRIM(ev) > 0) READ(ev,*,IOSTAT=ios) awd_step
+       CALL GET_ENVIRONMENT_VARIABLE('WRFGPU2_AWD_RK', ev)
+       IF (LEN_TRIM(ev) > 0) READ(ev,*,IOSTAT=ios) awd_rk
+       CALL GET_ENVIRONMENT_VARIABLE('WRFGPU2_AWD_ITER', ev)
+       IF (LEN_TRIM(ev) > 0) READ(ev,*,IOSTAT=ios) awd_iter
+       CALL GET_ENVIRONMENT_VARIABLE('WRFGPU2_AWD_ROOT', ev)
+       IF (LEN_TRIM(ev) > 0) awd_root = TRIM(ev)
+       CALL execute_command_line('mkdir -p '//TRIM(awd_root), wait=.TRUE.)
+     END IF
+   END IF
+   awd_cur_step = itimestep
+   awd_cur_rk = rk_step
+   awd_cur_iter = iteration
+   awd_active = awd_enabled .AND. (itimestep == awd_step) .AND. &
+                (rk_step == awd_rk) .AND. (iteration == awd_iter)
+END SUBROUTINE wrfgpu2_awd_set_context
+!WRFGPU2_AWD_CTX_END
+
