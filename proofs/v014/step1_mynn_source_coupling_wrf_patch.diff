+!WRFGPU2_ORACLE  ----- per-scheme physics ground-truth savepoint dumper (WRF v4.7.1) -----
+!  Writes full-domain 3D/2D field snapshots to raw little-endian stream binary
+!  (ACCESS='STREAM'), one file per field, plus a per-scheme text sidecar listing
+!  field name / rank / shape / units so the Python post-processor can assemble an
+!  NPZ + manifest.json.  Used by the physics drivers (microphysics, surface, pbl,
+!  radiation) to capture INPUT state (tag 'in') and OUTPUT state (tag 'out')
+!  around each scheme call, for ONE chosen domain (grid id) and ONE timestep.
+!
+!  Design notes:
+!   * STREAM access => contiguous raw bytes, no Fortran record markers; numpy reads
+!     via np.fromfile(dtype='<f8') and reshapes with the recorded shape.
+!   * We dump the (i,k,j) physics layout exactly as the driver sees it, restricted
+!     to the tile interior [its:ite, kts:kte, jts:jte] for 3D and [its:ite,jts:jte]
+!     for 2D.  Serial run => one tile == full domain interior.
+!   * Arrays are written with an explicit k-collapse for 2D so the post-processor
+!     always reshapes as (nj, nk, ni) C-order after we write j-outer, k-mid, i-inner.
+!   * Activation is gated by an environment variable WRFGPU2_ORACLE=1 and a target
+!     domain id WRFGPU2_ORACLE_GRID (default 2) and target itimestep
+!     WRFGPU2_ORACLE_STEP (default: first time the scheme is seen on that grid).
+!
+MODULE module_wrfgpu2_oracle
+
+  IMPLICIT NONE
+  PRIVATE
+  PUBLIC :: oracle_enabled, oracle_want, oracle_dump3d, oracle_dump2d, &
+            oracle_open_scheme, oracle_close_scheme
+
+  CHARACTER(LEN=512), SAVE :: out_root = '/mnt/data/wrf_gpu2/physics_oracle'
+  LOGICAL, SAVE :: g_enabled = .FALSE.
+  LOGICAL, SAVE :: g_inited  = .FALSE.
+  INTEGER, SAVE :: g_grid    = 2
+  INTEGER, SAVE :: g_step    = -1        ! -1 => first seen
+  INTEGER, SAVE :: g_sidecar = -1        ! open sidecar unit, -1 if none
+
+CONTAINS
+
+  SUBROUTINE oracle_init()
+    CHARACTER(LEN=64) :: ev
+    INTEGER :: ios, ival
+    IF (g_inited) RETURN
+    g_inited = .TRUE.
+    CALL GET_ENVIRONMENT_VARIABLE('WRFGPU2_ORACLE', ev)
+    IF (TRIM(ev) == '1') g_enabled = .TRUE.
+    CALL GET_ENVIRONMENT_VARIABLE('WRFGPU2_ORACLE_GRID', ev)
+    IF (LEN_TRIM(ev) > 0) THEN
+      READ(ev,*,IOSTAT=ios) ival
+      IF (ios == 0) g_grid = ival
+    END IF
+    CALL GET_ENVIRONMENT_VARIABLE('WRFGPU2_ORACLE_STEP', ev)
+    IF (LEN_TRIM(ev) > 0) THEN
+      READ(ev,*,IOSTAT=ios) ival
+      IF (ios == 0) g_step = ival
+    END IF
+    CALL GET_ENVIRONMENT_VARIABLE('WRFGPU2_ORACLE_ROOT', ev)
+    IF (LEN_TRIM(ev) > 0) out_root = TRIM(ev)
+  END SUBROUTINE oracle_init
+
+  LOGICAL FUNCTION oracle_enabled()
+    CALL oracle_init()
+    oracle_enabled = g_enabled
+  END FUNCTION oracle_enabled
+
+  ! Decide whether to dump for this (grid_id, itimestep). If g_step<0 we latch the
+  ! first itimestep we are asked about for the target grid and only dump that one.
+  LOGICAL FUNCTION oracle_want(grid_id, itimestep)
+    INTEGER, INTENT(IN) :: grid_id, itimestep
+    CALL oracle_init()
+    oracle_want = .FALSE.
+    IF (.NOT. g_enabled) RETURN
+    IF (grid_id /= g_grid) RETURN
+    IF (g_step < 0) THEN
+      g_step = itimestep      ! latch first seen step on the target grid
+    END IF
+    IF (itimestep == g_step) oracle_want = .TRUE.
+  END FUNCTION oracle_want
+
+  ! Open a per-scheme sidecar text file (subdir under out_root). tag e.g. 'in'/'out'.
+  SUBROUTINE oracle_open_scheme(subdir, scheme, tag, grid_id, itimestep, &
+                                ni, nk, nj)
+    CHARACTER(LEN=*), INTENT(IN) :: subdir, scheme, tag
+    INTEGER, INTENT(IN) :: grid_id, itimestep, ni, nk, nj
+    CHARACTER(LEN=1024) :: path
+    CALL execute_command_line('mkdir -p '//TRIM(out_root)//'/'//TRIM(subdir), &
+                              wait=.TRUE.)
+    WRITE(path,'(A)') TRIM(out_root)//'/'//TRIM(subdir)//'/'//TRIM(scheme)//'_'// &
+                      TRIM(tag)//'.sidecar.txt'
+    OPEN(NEWUNIT=g_sidecar, FILE=TRIM(path), STATUS='REPLACE', ACTION='WRITE', &
+         FORM='FORMATTED')
+    WRITE(g_sidecar,'(A)')     '# WRFGPU2 physics oracle sidecar'
+    WRITE(g_sidecar,'(A,A)')   'scheme '//TRIM(scheme), ''
+    WRITE(g_sidecar,'(A,A)')   'tag '//TRIM(tag), ''
+    WRITE(g_sidecar,'(A,I0)')  'grid_id ', grid_id
+    WRITE(g_sidecar,'(A,I0)')  'itimestep ', itimestep
+    WRITE(g_sidecar,'(A,3(1X,I0))') 'dims_ni_nk_nj', ni, nk, nj
+    WRITE(g_sidecar,'(A)')     '# FIELD name rank ni nk nj units stagger desc'
+  END SUBROUTINE oracle_open_scheme
+
+  SUBROUTINE oracle_close_scheme()
+    IF (g_sidecar > 0) THEN
+      CLOSE(g_sidecar)
+      g_sidecar = -1
+    END IF
+  END SUBROUTINE oracle_close_scheme
+
+  ! Dump a 3D (i,k,j) physics array over the tile interior to a stream binary file,
+  ! and append a FIELD line to the sidecar. Writes j-outer, k-mid, i-inner so the
+  ! reader reshapes contiguous bytes as numpy shape (nj, nk, ni).
+  SUBROUTINE oracle_dump3d(subdir, scheme, tag, name, units, stagger, desc, &
+                           arr, ims,ime,kms,kme,jms,jme, its,ite,kts,kte,jts,jte)
+    CHARACTER(LEN=*), INTENT(IN) :: subdir, scheme, tag, name, units, stagger, desc
+    INTEGER, INTENT(IN) :: ims,ime,kms,kme,jms,jme, its,ite,kts,kte,jts,jte
+    REAL,    INTENT(IN) :: arr(ims:ime,kms:kme,jms:jme)
+    CHARACTER(LEN=1024) :: path
+    INTEGER :: u, i, k, j, ni, nk, nj
+    REAL(KIND=8), ALLOCATABLE :: buf(:)
+    INTEGER :: p
+    ni = ite-its+1; nk = kte-kts+1; nj = jte-jts+1
+    ALLOCATE(buf(ni*nk*nj))
+    p = 0
+    DO j = jts, jte
+      DO k = kts, kte
+        DO i = its, ite
+          p = p + 1
+          buf(p) = REAL(arr(i,k,j), KIND=8)
+        END DO
+      END DO
+    END DO
+    WRITE(path,'(A)') TRIM(out_root)//'/'//TRIM(subdir)//'/'//TRIM(scheme)//'_'// &
+                      TRIM(tag)//'__'//TRIM(name)//'.f64'
+    OPEN(NEWUNIT=u, FILE=TRIM(path), STATUS='REPLACE', ACTION='WRITE', &
+         FORM='UNFORMATTED', ACCESS='STREAM')
+    WRITE(u) buf
+    CLOSE(u)
+    DEALLOCATE(buf)
+    IF (g_sidecar > 0) THEN
+      WRITE(g_sidecar,'(A,1X,A,1X,I0,3(1X,I0),1X,A,1X,A,1X,A)') &
+        'FIELD', TRIM(name), 3, ni, nk, nj, TRIM(units), TRIM(stagger), TRIM(desc)
+    END IF
+  END SUBROUTINE oracle_dump3d
+
+  ! Dump a 2D (i,j) physics array over the tile interior. nk recorded as 1.
+  SUBROUTINE oracle_dump2d(subdir, scheme, tag, name, units, stagger, desc, &
+                           arr, ims,ime,jms,jme, its,ite,jts,jte)
+    CHARACTER(LEN=*), INTENT(IN) :: subdir, scheme, tag, name, units, stagger, desc
+    INTEGER, INTENT(IN) :: ims,ime,jms,jme, its,ite,jts,jte
+    REAL,    INTENT(IN) :: arr(ims:ime,jms:jme)
+    CHARACTER(LEN=1024) :: path
+    INTEGER :: u, i, j, ni, nj, p
+    REAL(KIND=8), ALLOCATABLE :: buf(:)
+    ni = ite-its+1; nj = jte-jts+1
+    ALLOCATE(buf(ni*nj))
+    p = 0
+    DO j = jts, jte
+      DO i = its, ite
+        p = p + 1
+        buf(p) = REAL(arr(i,j), KIND=8)
+      END DO
+    END DO
+    WRITE(path,'(A)') TRIM(out_root)//'/'//TRIM(subdir)//'/'//TRIM(scheme)//'_'// &
+                      TRIM(tag)//'__'//TRIM(name)//'.f64'
+    OPEN(NEWUNIT=u, FILE=TRIM(path), STATUS='REPLACE', ACTION='WRITE', &
+         FORM='UNFORMATTED', ACCESS='STREAM')
+    WRITE(u) buf
+    CLOSE(u)
+    DEALLOCATE(buf)
+    IF (g_sidecar > 0) THEN
+      WRITE(g_sidecar,'(A,1X,A,1X,I0,3(1X,I0),1X,A,1X,A,1X,A)') &
+        'FIELD', TRIM(name), 2, ni, 1, nj, TRIM(units), TRIM(stagger), TRIM(desc)
+    END IF
+  END SUBROUTINE oracle_dump2d
+
+END MODULE module_wrfgpu2_oracle
