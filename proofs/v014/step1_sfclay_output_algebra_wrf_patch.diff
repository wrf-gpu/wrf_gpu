+                 ZA(I), ZNT(I), z_t(I), z_q(I), WSPD(I), FLHC(I), FLQC(I), CHS(I), CHS2(I), CQS2(I), MOL(I), RMOL(I)
+         ENDDO
+         CLOSE(wrfgpu2_unit)
+      ENDIF
+   ENDIF

 END SUBROUTINE SFCLAY1D_mynn
