diff --git a/phys/module_sf_mynn.F b/phys/module_sf_mynn.F
--- a/phys/module_sf_mynn.F
+++ b/phys/module_sf_mynn.F
@@
   USE module_model_constants, only: &
        &p1000mb, ep_2
