# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Logs and local outputs
*.log
logs/
tmp/

# Large model and weather artifacts
artifacts/*
!artifacts/README.md
!artifacts/.gitkeep
fixtures/**/*.nc
fixtures/**/*.nc4
fixtures/**/*.grib
fixtures/**/*.grb
fixtures/**/*.grib2
fixtures/**/*.grb2
fixtures/**/*.h5
fixtures/**/*.hdf5
fixtures/**/*.zarr/
fixtures/**/*.bin
fixtures/**/*.npy
fixtures/**/*.npz
*.nc
*.nc4
*.grib
*.grb
*.grib2
*.grb2
*.h5
*.hdf5
*.zarr/
*.zarr
*.bin
*.npy
*.npz

# Profilers
*.ncu-rep
*.nsys-rep
*.qdrep
*.sqlite-shm
*.sqlite-wal
*.sqlite
profiler_outputs/

# Build products
build/
dist/
*.egg-info/

# gpuwrf run artifacts (Quickstart): XLA cache + forecast output dirs
.gpuwrf-cache/
/runs/

# External fixture / runs / profiler storage
# `data` is a symlink to /mnt/data/wrf_gpu2 (created by scripts/bootstrap_storage.sh)
data
data/
# Exception: small in-repo manifests committed under data/manifests/ (M7-S0a F-S0a-1)
!data/manifests/
!data/manifests/**

# Dispatch bookkeeping (auto-generated per role per sprint by scripts/dispatch_role.sh)
.agent/sprints/*/.worker-*
.agent/sprints/*/.tester-*
.agent/sprints/*/.reviewer-*
.agent/sprints/*/.critical-review-*
.agent/sprints/*/role-prompts/

# Claude Code scheduled-task lock
.claude/scheduled_tasks.lock


# publish/ = local working folder (paper drafts, figures, analysis) — NOT part of the release
/publish/

# Agent/tooling sandboxes and local caches — NOT part of the release
# (gitignore does not support trailing inline comments; keep patterns bare)
# .codex/        Codex/GPT worker git worktrees (multi-GB scratch)
# .claude/worktrees/  Claude Code agent git worktrees
# .agents/       transient agent scratch dir
# cache/         local tool cache (e.g. projects.json)
# .gpuwrf-cache*/  any JIT/compile cache variant left in-tree
.codex/
.claude/worktrees/
.agents/
cache/
.gpuwrf-cache*/

# Editor / OS backups and cruft
*~
*.swp
*.swo
*.bak
*.orig
.DS_Store
Thumbs.db
