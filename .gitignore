*.log
logs/
tmp/

# Large model and weather artifacts
artifacts/*
!artifacts/README.md
!artifacts/.gitkeep
fixtures/**/*.nc
fixtures/**/*.nc4
fixtures/**/*.grib
fixtures/**/*.grb
fixtures/**/*.grib2
fixtures/**/*.grb2
