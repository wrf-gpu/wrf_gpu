+        snapshot = {name: jnp.asarray(after_boundary[name]) for name in COUPLED_STATE_FIELDS if name in after_boundary}
+        snapshot.update({name: jnp.asarray(value) for name, value in physics_tendencies.items()})
+        snapshot.update({name: jnp.asarray(value) for name, value in boundary_tendencies.items()})
+        host_snapshot = {name: np.asarray(snapshot[name], dtype=np.float64) for name in COMPARE_FIELDS}
+        snapshots.append(host_snapshot)
+        carry = _carry_from_coupled_core(
+            snapshot,
+            dycore_carry.state,
+            theta_offset,
+            float(attrs["dt"]),
+            rthraten=dycore_carry.rthraten,
+        )
+    context = {"attrs": attrs, "initial": acoustic, "extras": extras, "grid": grid}
+    _FULL_STEP_CACHE[cache_key] = (snapshots, context)
+    return snapshots, context
+
