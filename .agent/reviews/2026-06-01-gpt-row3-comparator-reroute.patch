+def _slice_full_snapshot(snapshot: dict[str, np.ndarray], attrs: dict[str, object]) -> dict[str, np.ndarray]:
+    ys, xs = _slice_attrs(attrs)
+    u_x = slice(xs.start, xs.stop + 1)
+    v_y = slice(ys.start, ys.stop + 1)
+    sliced: dict[str, np.ndarray] = {}
+    for name in COMPARE_FIELDS:
+        array = np.asarray(snapshot[name], dtype=np.float64)
+        if name in {"u", "u_phys_tend"}:
+            sliced[name] = array[:, ys, u_x]
+        elif name in {"v", "v_phys_tend"}:
+            sliced[name] = array[:, v_y, xs]
+        elif name in {"mu", "mut", "mudf", "muts", "muave", "mu_bdy_tend"}:
+            sliced[name] = array[ys, xs]
+        else:
+            sliced[name] = array[:, ys, xs]
+    return sliced
+
