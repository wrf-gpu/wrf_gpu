+def _run_full_coupled_steps(steps: int) -> tuple[list[dict[str, np.ndarray]], dict[str, Any]]:
+    cache_key = (str(SOURCE_WRFOUT), str(SOURCE_WRFBDY), int(steps))
+    if cache_key in _FULL_STEP_CACHE:
+        return _FULL_STEP_CACHE[cache_key]
+
+    acoustic, attrs, extras = _load_full_initial_state()
+    metrics = _m6b4._metrics()
+    grid = _tier_grid(attrs, metrics, acoustic)
+    state = _enforce_operational_precision(
+        _state_from_m6b6_acoustic(acoustic, attrs, extras),
+        force_fp64=True,
+    )
+    namelist = _operational_namelist(attrs, grid, metrics, state, acoustic)
+    carry = initial_operational_carry(state)
+    cfg = _cfg(attrs)
+    theta_offset = jnp.asarray(300.0, dtype=state.theta.dtype)
+    snapshots: list[dict[str, np.ndarray]] = []
+    for step_index in range(1, int(steps) + 1):
+        lead_seconds = jnp.asarray((step_index - 1) * float(attrs["dt"]), dtype=jnp.float64)
+        dycore_carry = _rk_scan_step(carry, namelist, lead_seconds=lead_seconds)
+        dycore_snapshot = _snapshot_from_operational_carry(dycore_carry)
+        after_physics, physics_tendencies = _physics_update(dycore_snapshot, extras, cfg)
