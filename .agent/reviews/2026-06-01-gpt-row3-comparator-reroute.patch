+def _extra_array(extras: dict[str, np.ndarray], name: str, shape: tuple[int, ...], default: float):
+    if name in extras:
+        return jnp.asarray(extras[name], dtype=jnp.float64)
+    return jnp.ones(shape, dtype=jnp.float64) * float(default)
