+    v_y = slice(ys.start, ys.stop + 1)
+    full = _m6b4._metrics()
+    return DycoreMetrics(
+        msftx=full.msftx[ys, xs],
+        msfty=full.msfty[ys, xs],
+        msfux=full.msfux[ys, u_x],
+        msfuy=full.msfuy[ys, u_x],
+        msfvx=full.msfvx[v_y, xs],
+        msfvy=full.msfvy[v_y, xs],
+        c1h=full.c1h,
+        c2h=full.c2h,
+        c3h=full.c3h,
