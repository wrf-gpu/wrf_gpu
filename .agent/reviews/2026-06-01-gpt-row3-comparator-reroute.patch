+        phb = jnp.asarray(ds.variables["PHB"][0, :, ys, xs], dtype=jnp.float64)
+
+    p_pert = jnp.asarray(acoustic["p"], dtype=jnp.float64)
+    ph_pert = jnp.asarray(acoustic["ph"], dtype=jnp.float64)
+    mu_pert = jnp.asarray(acoustic["mu"], dtype=jnp.float64)
+    mub = jnp.asarray(acoustic["mut"], dtype=jnp.float64)
+    theta = theta_pert + 300.0
+    p_total = pb + p_pert
+    ph_total = phb + ph_pert
+    mu_total = mub + mu_pert
+    return State(
+        u=jnp.asarray(acoustic["u"], dtype=jnp.float64),
+        v=jnp.asarray(acoustic["v"], dtype=jnp.float64),
+        w=jnp.asarray(acoustic["w"], dtype=jnp.float64),
+        theta=theta,
+        qv=_extra_array(extras, "qv", mass, 0.010),
+        p=p_total,
+        ph=ph_total,
+        mu=mu_total,
+        p_total=p_total,
+        p_perturbation=p_pert,
+        ph_total=ph_total,
+        ph_perturbation=ph_pert,
