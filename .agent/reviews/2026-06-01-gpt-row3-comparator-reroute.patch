+def _m6b1_face_average_u(mass: np.ndarray) -> np.ndarray:
+    ny, nx = mass.shape
+    out = np.empty((ny, nx + 1), dtype=np.float64)
+    out[:, 0] = mass[:, 0]
+    out[:, -1] = mass[:, -1]
+    out[:, 1:-1] = 0.5 * (mass[:, :-1] + mass[:, 1:])
+    return out
+
+
+def _m6b1_face_average_v(mass: np.ndarray) -> np.ndarray:
+    ny, nx = mass.shape
+    out = np.empty((ny + 1, nx), dtype=np.float64)
+    out[0, :] = mass[0, :]
+    out[-1, :] = mass[-1, :]
+    out[1:-1, :] = 0.5 * (mass[:-1, :] + mass[1:, :])
+    return out
+
+
+def _sliced_metrics(attrs: dict[str, object]) -> DycoreMetrics:
+    """Return WRF metrics sliced to the same tier tile as the M6B state."""
+
+    ys, xs = _slice_attrs(attrs)
