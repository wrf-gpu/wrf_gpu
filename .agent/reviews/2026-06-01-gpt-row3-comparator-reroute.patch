+def _projection_kind(map_proj: object) -> str:
+    try:
+        value = int(map_proj)
+    except (TypeError, ValueError):
+        value = 1
+    if value == 2:
+        return "polar"
+    if value == 3:
+        return "mercator"
+    return "lambert"
+
+
+def _tier_grid(attrs: dict[str, object], metrics: DycoreMetrics, acoustic_state: dict[str, np.ndarray]) -> GridSpec:
+    theta = np.asarray(acoustic_state["theta"], dtype=np.float64)
+    nz, ny, nx = (int(dim) for dim in theta.shape)
+    ys, xs = _slice_attrs(attrs)
+    with Dataset(SOURCE_WRFOUT) as ds:
+        if "HGT" in ds.variables:
+            terrain_np = np.asarray(ds.variables["HGT"][0, ys, xs], dtype=np.float64)
+        elif "PHB" in ds.variables:
+            terrain_np = np.asarray(ds.variables["PHB"][0, 0, ys, xs], dtype=np.float64) / 9.81
+        else:
+            terrain_np = np.zeros((ny, nx), dtype=np.float64)
+        if "ZNW" in ds.variables:
+            eta_levels_np = np.asarray(ds.variables["ZNW"][0], dtype=np.float64)
+        else:
+            eta_levels_np = np.asarray(metrics.c1f, dtype=np.float64)
+        projection = Projection(
+            _projection_kind(getattr(ds, "MAP_PROJ", 1)),  # type: ignore[arg-type]
+            float(getattr(ds, "CEN_LAT", getattr(ds, "TRUELAT1", 0.0))),
+            float(getattr(ds, "CEN_LON", getattr(ds, "STAND_LON", 0.0))),
+            float(attrs["dx"]),
+            float(attrs["dy"]),
+            nx,
+            ny,
+        )
+    terrain_hash = hashlib.sha256(np.asarray(terrain_np, dtype=np.float64).tobytes()).hexdigest()
+    terrain = TerrainProvenance(
+        source_path=str(SOURCE_WRFOUT),
+        sha256=terrain_hash,
+        shape=(ny, nx),
+        units="m",
+        projection_transform="native-wrf-tier-slice",
+        max_elevation_m=float(np.nanmax(terrain_np)) if terrain_np.size else 0.0,
+        coastline_sanity_check_passed=True,
+    )
+    eta_levels = jnp.asarray(eta_levels_np, dtype=jnp.float64)
+    vertical = VerticalCoord(
+        "hybrid_eta",
+        nz,
+        float(np.asarray(metrics.p_top)),
+        eta_levels,
+    )
+    bc = BCMetadata(
+        source="AIFS",
+        fields=("U", "V", "T", "QVAPOR", "PH", "MU"),
+        update_cadence_h=1,
+        interpolation="linear",
+        restart_compatible=False,
+    )
+    return GridSpec(
+        projection,
+        terrain,
+        vertical,
+        bc,
+        eta_levels,
+        jnp.asarray(terrain_np, dtype=jnp.float64),
+        metrics=metrics,
+        halo_width=2,
+    )
+
