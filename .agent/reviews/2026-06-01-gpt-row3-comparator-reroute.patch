+def _load_full_initial_state() -> tuple[dict[str, np.ndarray], dict[str, object], dict[str, np.ndarray]]:
+    with Dataset(SOURCE_WRFOUT) as ds:
+        ny = len(ds.dimensions["south_north"])
+        nx = len(ds.dimensions["west_east"])
+        ys = slice(0, ny)
+        xs = slice(0, nx)
+        u_x = slice(0, nx + 1)
+        v_y = slice(0, ny + 1)
+        theta = np.asarray(ds.variables["T"][0, :, ys, xs], dtype=np.float64)
+        mu = np.asarray(ds.variables["MU"][0, ys, xs], dtype=np.float64)
+        mut = np.asarray(ds.variables["MUB"][0, ys, xs], dtype=np.float64)
+        total_mass = mut + mu
+        ww = np.zeros((theta.shape[0] + 1, ny, nx), dtype=np.float64)
+        acoustic = {
+            "ww": ww,
+            "ww_1": np.zeros_like(ww),
+            "u": np.asarray(ds.variables["U"][0, :, ys, u_x], dtype=np.float64),
+            "u_1": np.asarray(ds.variables["U"][0, :, ys, u_x], dtype=np.float64),
+            "v": np.asarray(ds.variables["V"][0, :, v_y, xs], dtype=np.float64),
+            "v_1": np.asarray(ds.variables["V"][0, :, v_y, xs], dtype=np.float64),
+            "w": np.asarray(ds.variables["W"][0, :, ys, xs], dtype=np.float64),
+            "mu": mu,
+            "mut": mut,
+            "muave": np.zeros_like(mu),
+            "muts": total_mass,
+            "muu": _m6b1_face_average_u(total_mass),
+            "muv": _m6b1_face_average_v(total_mass),
+            "mudf": np.zeros_like(mu),
+            "theta": theta,
+            "theta_1": theta.copy(),
+            "theta_ave": np.zeros_like(theta),
+            "theta_tend": np.zeros_like(theta),
+            "mu_tend": np.zeros_like(mu),
+            "ph_tend": np.zeros_like(ww),
+            "ph": np.asarray(ds.variables["PH"][0, :, ys, xs], dtype=np.float64),
+            "p": np.asarray(ds.variables["P"][0, :, ys, xs], dtype=np.float64),
+            "t_2ave": np.zeros_like(theta),
+        }
+        attrs = {
+            "dt": float(getattr(ds, "DT", 6.0)),
+            "dx": float(getattr(ds, "DX", 3000.0)),
+            "dy": float(getattr(ds, "DY", 3000.0)),
+            "epssm": float(getattr(ds, "EPSSM", 0.1) or 0.1),
+            "run_id": f"m6b6-full-{SOURCE_WRFOUT.name}",
+            "target_slice_y": [0, ny],
+            "target_slice_x": [0, nx],
+            "halo_slice_y": [0, ny],
+            "halo_slice_x": [0, nx],
+            "mapfac_min": float(np.nanmin(ds.variables["MAPFAC_MY"][0, ys, xs])),
+            "mapfac_max": float(np.nanmax(ds.variables["MAPFAC_MY"][0, ys, xs])),
+        }
+    return acoustic, attrs, _physics_boundary_extras(attrs, acoustic)
