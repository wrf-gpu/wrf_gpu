+        c1f=full.c1f,
+        c2f=full.c2f,
+        c3f=full.c3f,
+        c4f=full.c4f,
+        dn=full.dn,
+        dnw=full.dnw,
+        rdn=full.rdn,
+        rdnw=full.rdnw,
+        cf1=full.cf1,
+        cf2=full.cf2,
+        cf3=full.cf3,
+        fnm=full.fnm,
+        fnp=full.fnp,
+        dzdx=full.dzdx[ys, xs],
+        dzdy=full.dzdy[ys, xs],
+        dzdx_u=full.dzdx_u[ys, u_x],
+        dzdy_v=full.dzdy_v[v_y, xs],
+        f=full.f[ys, xs],
+        e=full.e[ys, xs],
+        sina=full.sina[ys, xs],
+        cosa=full.cosa[ys, xs],
+        p_top=full.p_top,
+        provenance=f"{full.provenance}; m6b6-tier-slice-y{ys.start}:{ys.stop}-x{xs.start}:{xs.stop}",
